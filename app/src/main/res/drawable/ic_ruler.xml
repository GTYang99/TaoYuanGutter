<?xml version="1.0" encoding="utf-8"?>
<!--
    水平尺形圖示（材質設計風格）。
    app:tint 會套用 FAB 顏色，icon 本身的 strokeColor 僅作為 fallback。
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- 尺身外框 -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FF000000"
        android:strokeWidth="1.6"
        android:strokeLineJoin="round"
        android:pathData="M2,7 L22,7 L22,17 L2,17 Z" />

    <!-- 刻度線：短（4 條） -->
    <path
        android:strokeColor="#FF000000"
        android:strokeWidth="1.4"
        android:strokeLineCap="round"
        android:pathData="M6,7 L6,11" />
    <path
        android:strokeColor="#FF000000"
        android:strokeWidth="1.4"
        android:strokeLineCap="round"
        android:pathData="M10,7 L10,11" />
    <path
        android:strokeColor="#FF000000"
        android:strokeWidth="1.4"
        android:strokeLineCap="round"
        android:pathData="M14,7 L14,11" />
    <path
        android:strokeColor="#FF000000"
        android:strokeWidth="1.4"
        android:strokeLineCap="round"
        android:pathData="M18,7 L18,11" />

    <!-- 刻度線：長（中間，1 條） -->
    <path
        android:strokeColor="#FF000000"
        android:strokeWidth="1.4"
        android:strokeLineCap="round"
        android:pathData="M12,7 L12,13" />

</vector>
