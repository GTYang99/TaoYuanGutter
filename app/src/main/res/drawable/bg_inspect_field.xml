<?xml version="1.0" encoding="utf-8"?>
<!--
    檢視模式唯讀欄位背景：
    - 白色底色，圓角 4dp
    - 淡灰實線描邊
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/white" />
    <stroke
        android:width="1dp"
        android:color="#E0E0E0" />
    <corners android:radius="4dp" />
</shape>
