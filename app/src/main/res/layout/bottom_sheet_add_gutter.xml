<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_form_sheet"
    android:orientation="vertical">

    <!-- Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_drag_handle" />

    <!-- Header Row: [<] 新增側溝 [+] -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="4dp">

        <!-- 關閉按鈕（左，返回箭頭，一般模式） -->
        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="關閉"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/text_grey" />

        <!-- 取消按鈕（左，文字，離線模式，預設 GONE） -->
        <TextView
            android:id="@+id/tvCancel"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:text="取消"
            android:textColor="@color/colorPrimary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone" />

        <!-- 標題 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="新增側溝"
            android:textColor="@color/text_grey"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- 新增節點按鈕（右） -->
        <ImageButton
            android:id="@+id/btnAddNode"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="新增節點"
            android:padding="12dp"
            android:src="@drawable/ic_add"
            app:tint="@color/colorPrimary" />

    </RelativeLayout>

    <!-- 分隔線 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_grey" />

    <!-- 節點清單（佔剩餘空間） -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvWaypoints"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="4dp"
        android:paddingBottom="4dp" />

    <!-- 底部分隔線 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_grey" />

    <!-- 新增側溝按鈕 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmitGutter"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_margin="16dp"
        android:text="@string/btn_add_gutter"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/colorPrimary"
        app:cornerRadius="12dp" />

</LinearLayout>
