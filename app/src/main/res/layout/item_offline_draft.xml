<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:paddingHorizontal="20dp"
    android:paddingVertical="14dp">

    <!-- 側溝編號 -->
    <TextView
        android:id="@+id/tvDraftGutterId"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/text_grey"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnDeleteDraft"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 側溝形式 -->
    <TextView
        android:id="@+id/tvDraftGutterType"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/inputFieldHint"
        android:textSize="13sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnDeleteDraft"
        app:layout_constraintTop_toBottomOf="@id/tvDraftGutterId" />

    <!-- 儲存時間 -->
    <TextView
        android:id="@+id/tvDraftDate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/inputFieldHint"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnDeleteDraft"
        app:layout_constraintTop_toBottomOf="@id/tvDraftGutterType" />

    <!-- 刪除按鈕 -->
    <ImageButton
        android:id="@+id/btnDeleteDraft"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_close"
        android:contentDescription="刪除草稿"
        android:padding="6dp"
        app:tint="@color/inputFieldHint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- 分隔線 -->
    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/border_grey"
        android:layout_marginTop="14dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDraftDate" />

</androidx.constraintlayout.widget.ConstraintLayout>
