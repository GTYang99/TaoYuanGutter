<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/locationPickerOverlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="false"
    android:focusable="false"
    android:visibility="gone">

    <!-- 頂部提示長框（攔截觸碰，不讓地圖誤觸） -->
    <LinearLayout
        android:id="@+id/topPickerBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:backgroundTint="@color/colorPrimary"
        android:clickable="true"
        android:elevation="6dp"
        android:focusable="true"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawablePadding="8dp"
            android:text="@string/picker_hint"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 準心（固定在畫面中心，不攔截觸碰） -->
    <ImageView
        android:id="@+id/ivCrosshair"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:clickable="false"
        android:focusable="false"
        android:src="@drawable/ic_crosshair"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 現在位置 FAB（右下角，底部按鈕列上方） -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabMyLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:clickable="true"
        android:elevation="8dp"
        android:focusable="true"
        android:textSize="13sp"
        app:icon="@drawable/ic_my_location"
        app:backgroundTint="@color/white"
        app:tint="@color/colorPrimary"
        app:layout_constraintBottom_toTopOf="@id/bottomPickerBar"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 底部按鈕列（攔截觸碰） -->
    <LinearLayout
        android:id="@+id/bottomPickerBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:clickable="true"
        android:elevation="6dp"
        android:focusable="true"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- 取消按鈕（左） -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelPick"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="@string/cancel"
            android:textColor="@color/white"
            android:backgroundTint="@color/colorOnCancel"
            android:textSize="15sp"
            app:cornerRadius="10dp"
            app:strokeWidth="1.5dp" />

        <!-- 確認按鈕（右） -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmPick"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/confirm"
            android:textColor="@color/white"
            android:textSize="15sp"
            app:backgroundTint="@color/colorPrimary"
            app:cornerRadius="10dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
