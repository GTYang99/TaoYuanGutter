<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_form_sheet"
    android:clipToOutline="true"
    android:outlineProvider="background">

    <!-- AppBar：標題列 + 分頁按鈕 -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar"
        app:elevation="4dp">

        <!-- 標題列：左側返回 + 置中標題 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/white">

            <!-- 左側：返回箭頭 -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="返回"
                android:padding="12dp" />

            <!-- 置中標題（側溝編號 XXXX-XXXX） -->
            <TextView
                android:id="@+id/tvInspectTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                android:text="側溝檢視" />

            <!-- 右側：編輯按鈕 -->
            <ImageButton
                android:id="@+id/btnEdit"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_edit"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/form_edit"
                android:padding="12dp" />

        </LinearLayout>

        <!-- 分頁切換按鈕列 -->
        <LinearLayout
            android:id="@+id/tabBar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="@color/white">

            <TextView
                android:id="@+id/btnTabBasicInfo"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/tab_basic_info"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@color/white"
                android:textColor="@color/colorPrimary"
                android:clickable="true"
                android:focusable="true" />

            <!-- 垂直分隔線 -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/border_grey" />

            <TextView
                android:id="@+id/btnTabPhotos"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="照片"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@color/white"
                android:textColor="@color/text_grey"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- 分頁底部指示條 -->
        <View
            android:id="@+id/tabIndicator"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:background="@color/colorPrimary" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ViewPager2：分頁內容 -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
