<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- 選點 Overlay（初始 GONE，選點時由 MainActivity 切換為 VISIBLE） -->

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="0dp" />

    <include
        android:id="@+id/locationPickerOverlay"
        layout="@layout/overlay_location_picker"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 登出文字按鈕（右上角，白色膠囊樣式） -->
    <TextView
        android:id="@+id/btnLogout"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:gravity="center"
        android:text="登出"
        android:textColor="#333333"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/bg_logout_chip"
        android:elevation="4dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 新增側溝 FAB（右下角，主要動作） -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnAddGutter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="96dp"
        android:contentDescription="新增側溝"
        android:src="@drawable/ic_add"
        app:backgroundTint="@color/colorPrimary"
        app:tint="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Map Buttons Container（右側，登出按鈕下方） -->
    <LinearLayout
        android:id="@+id/mapButtonsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/btnLogout"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 草稿紀錄按鈕 -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnViewDrafts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="離線草稿紀錄"
            android:src="@drawable/ic_note"
            app:backgroundTint="@color/fab_selector"
            app:tint="@color/fab_icon_selector"
            app:fabSize="mini" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnLegend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="@string/legend_title"
            android:src="@drawable/ic_info"
            app:backgroundTint="@color/fab_selector"
            app:tint="@color/fab_icon_selector"
            app:fabSize="mini" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnLayers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="@string/layers_title"
            android:src="@drawable/ic_layers"
            app:backgroundTint="@color/fab_selector"
            app:tint="@color/fab_icon_selector"
            app:fabSize="mini" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnMyLocation"
            android:layout_width="wrap_content"
            android:layout_height="82dp"
            android:contentDescription="@string/my_location_title"
            android:src="@drawable/ic_my_location"
            app:backgroundTint="@color/fab_selector"
            app:fabSize="mini"
            app:tint="@color/fab_icon_selector" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
