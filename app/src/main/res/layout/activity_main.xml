<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- 選點 Overlay（初始 GONE，選點時由 MainActivity 切換為 VISIBLE） -->

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="0dp" />

    <include
        android:id="@+id/locationPickerOverlay"
        layout="@layout/overlay_location_picker"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 新增側溝 FAB（左下角，主要動作） -->
    <!-- 調整 marginBottom 到 112dp (16dp + 80dp + 16dp)，使其位於選點 Overlay 的按鈕列上方 -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnAddGutter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="96dp"
        android:contentDescription="新增側溝"
        android:src="@drawable/ic_add"
        app:backgroundTint="@color/colorPrimary"
        app:tint="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Map Buttons Container（右下角） -->
    <!-- 調整 marginBottom 到 112dp，使其底部與左側 + 號按鈕對齊 -->
    <LinearLayout
        android:id="@+id/mapButtonsContainer"
        android:layout_width="wrap_content"
        android:layout_height="180dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="100dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnLegend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="@string/legend_title"
            android:src="@drawable/ic_info"
            app:backgroundTint="@color/fab_selector"
            app:tint="@color/fab_icon_selector"
            app:fabSize="mini" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnLayers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="@string/layers_title"
            android:src="@drawable/ic_layers"
            app:backgroundTint="@color/fab_selector"
            app:tint="@color/fab_icon_selector"
            app:fabSize="mini" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnMyLocation"
            android:layout_width="wrap_content"
            android:layout_height="82dp"
            android:contentDescription="@string/my_location_title"
            android:src="@drawable/ic_my_location"
            app:backgroundTint="@color/fab_selector"
            app:fabSize="mini"
            app:tint="@color/fab_icon_selector" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
