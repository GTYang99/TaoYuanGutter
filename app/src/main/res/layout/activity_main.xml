<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- 選點 Overlay（初始 GONE，選點時由 MainActivity 切換為 VISIBLE） -->

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="0dp" />

    <include
        android:id="@+id/locationPickerOverlay"
        layout="@layout/overlay_location_picker"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 登出文字按鈕（右上角，白色膠囊樣式） -->
    <TextView
        android:id="@+id/btnLogout"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:gravity="center"
        android:text="@string/msg_logout"
        android:textColor="#333333"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/bg_logout_chip"
        android:elevation="4dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 新增側溝 FAB（右下角，主要動作） -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnAddGutter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="96dp"
        android:contentDescription="新增側溝"
        android:src="@drawable/ic_add"
        app:backgroundTint="@color/colorPrimary"
        app:tint="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Map Buttons Container（右側，登出按鈕下方） -->
    <LinearLayout
        android:id="@+id/mapButtonsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/btnLogout"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnLegend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="@string/legend_title"
            android:src="@drawable/ic_info_new"
            app:backgroundTint="@color/white"
            app:tint="@color/colorPrimary"
            app:fabSize="mini" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnLayers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="@string/layers_title"
            android:src="@drawable/ic_bx_layer"
            app:backgroundTint="@color/white"
            app:tint="@color/colorPrimary"
            app:fabSize="mini" />

        <!-- 草稿紀錄按鈕 -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnViewDrafts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="@string/unupload_data"
            android:src="@drawable/ic_tabler_cloud"
            app:backgroundTint="@color/white"
            app:tint="@color/colorPrimary"
            app:fabSize="mini" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnMyLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="@string/my_location_title"
            android:src="@drawable/ic_my_location"
            app:backgroundTint="@color/white"
            app:fabSize="mini"
            app:tint="@color/colorPrimary" />

        <!-- 測距模式按鈕（toggle） -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnMeasureDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/measure_mode_title"
            android:src="@drawable/ic_ruler"
            app:backgroundTint="@color/white"
            app:tint="@color/colorPrimary"
            app:fabSize="mini" />

    </LinearLayout>

    <!-- 測距準星（畫面正中央，測距模式時才顯示） -->
    <ImageView
        android:id="@+id/ivMeasureCrosshair"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_crosshair"
        android:visibility="gone"
        android:contentDescription="@string/measure_crosshair_desc"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 測距底部面板（測距模式時才顯示） -->
    <include
        android:id="@+id/measurePanel"
        layout="@layout/panel_measure_distance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 檢視側溝載入中 Overlay（點選側溝→等待資料/照片下載完成） -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/inspectLoadingOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#80000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

	        <ProgressBar
	            android:id="@+id/pbInspectLoading"
	            style="?android:attr/progressBarStyleLarge"
	            android:layout_width="wrap_content"
	            android:layout_height="wrap_content"
	            android:indeterminateTint="?attr/colorPrimary"
	            android:indeterminateTintMode="src_in"
	            app:layout_constraintTop_toTopOf="parent"
	            app:layout_constraintBottom_toBottomOf="parent"
	            app:layout_constraintStart_toStartOf="parent"
	            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvInspectLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="載入側溝資料中…"
            android:textColor="@color/white"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/pbInspectLoading"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 照片上傳進度提示（上傳期間顯示於畫面上方；需顯示在 overlay 上方） -->
    <TextView
        android:id="@+id/tvPhotoUploadProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:clickable="true"
        android:focusable="true"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:textColor="@color/textColorPrimary"
        android:textSize="13sp"
        android:textStyle="bold"
        android:background="@drawable/bg_logout_chip"
        android:elevation="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
