                android:visibility="visible"
                app:layout_constraintTop_toTopOf="@id/ratioAnchorE1"
                app:layout_constraintBottom_toBottomOf="@id/ratioAnchorE1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_camera"
                    android:scaleType="centerInside"
                    android:alpha="0.3"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_photo"
                    android:textSize="12sp"
                    android:textColor="@color/inputFieldHint"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/ivEndPhotoSlot1"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="@null"
                app:layout_constraintTop_toTopOf="@id/ratioAnchorE1"
                app:layout_constraintBottom_toBottomOf="@id/ratioAnchorE1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 終點②：側溝內徑寬度尺寸 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_photo_width"
            android:textSize="14sp"
            android:textColor="@color/textColorSecondary"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/photoEndSlot2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_photo_placeholder"
            android:clipToOutline="true"
            android:outlineProvider="background">

            <View
                android:id="@+id/ratioAnchorE2"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintDimensionRatio="H,4:3"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <LinearLayout
                android:id="@+id/placeholderEndSlot2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="visible"
                app:layout_constraintTop_toTopOf="@id/ratioAnchorE2"
                app:layout_constraintBottom_toBottomOf="@id/ratioAnchorE2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_camera"
                    android:scaleType="centerInside"
                    android:alpha="0.3"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_photo"
                    android:textSize="12sp"
                    android:textColor="@color/inputFieldHint"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/ivEndPhotoSlot2"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="@null"
                app:layout_constraintTop_toTopOf="@id/ratioAnchorE2"
                app:layout_constraintBottom_toBottomOf="@id/ratioAnchorE2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 終點③：側溝深度尺寸 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_photo_depth"
            android:textSize="14sp"
            android:textColor="@color/textColorSecondary"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/photoEndSlot3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_photo_placeholder"
            android:clipToOutline="true"
            android:outlineProvider="background">

            <View
                android:id="@+id/ratioAnchorE3"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintDimensionRatio="H,4:3"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <LinearLayout
                android:id="@+id/placeholderEndSlot3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="visible"
                app:layout_constraintTop_toTopOf="@id/ratioAnchorE3"
                app:layout_constraintBottom_toBottomOf="@id/ratioAnchorE3"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_camera"
                    android:scaleType="centerInside"
                    android:alpha="0.3"
                    android:contentDescription="@null" />

