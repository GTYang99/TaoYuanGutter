<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_form_sheet"
    android:orientation="vertical"
    android:paddingBottom="24dp">

    <!-- Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_drag_handle" />

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:text="@string/add_option_title"
        android:textColor="@color/text_grey"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_grey" />

    <!-- 新增側溝 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddGutter"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="@string/btn_add_gutter"
        android:textColor="@color/text_grey"
        android:textSize="16sp"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_add"
        app:iconGravity="textStart"
        app:iconTint="@color/colorPrimary"
        app:rippleColor="@color/brand_purple_light"
        app:strokeColor="@color/border_grey"
        app:strokeWidth="1dp" />

    <!-- 新增曲線 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddCurve"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/btn_add_curve"
        android:textColor="@color/text_grey"
        android:textSize="16sp"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_add"
        app:iconGravity="textStart"
        app:iconTint="@color/colorPrimary"
        app:rippleColor="@color/brand_purple_light"
        app:strokeColor="@color/border_grey"
        app:strokeWidth="1dp" />

</LinearLayout>
