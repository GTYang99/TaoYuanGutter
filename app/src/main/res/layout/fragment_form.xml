<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/spacing_medium"
    android:background="@color/colorBackground" 
    tools:context=".form.FormFragment">

    <!-- Screen Title -->
    <TextView
        android:id="@+id/formTitleTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/form_title"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Headline5"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp"/>

    <!-- Scrollable form content -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/formTitleTextView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/submitButton">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="80dp"> <!-- Add padding for button -->

            <!-- Name Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/nameTextInputLayout"
                style="@style/Login.InputField"
                android:layout_marginTop="16dp"
                android:hint="@string/form_field_name"
                app:startIconDrawable="@drawable/ic_person"
                app:startIconTint="@color/inputFieldHint"
                app:hintTextColor="@color/inputFieldHint"
                app:boxStrokeColor="@color/colorPrimary"
                app:passwordToggleEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/nameEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName|textCapWords"
                    android:textColor="@color/black"
                    android:textCursorDrawable="@null"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Email Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/emailTextInputLayout"
                style="@style/Login.InputField"
                android:layout_marginTop="16dp"
                android:hint="@string/form_field_email"
                app:startIconDrawable="@drawable/ic_email"
                app:startIconTint="@color/inputFieldHint"
                app:hintTextColor="@color/inputFieldHint"
                app:boxStrokeColor="@color/colorPrimary"
                app:passwordToggleEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/emailEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/black"
                    android:textCursorDrawable="@null"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Phone Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/phoneTextInputLayout"
                style="@style/Login.InputField"
                android:layout_marginTop="16dp"
                android:hint="@string/form_field_phone"
                app:startIconDrawable="@drawable/ic_phone"
                app:startIconTint="@color/inputFieldHint"
                app:hintTextColor="@color/inputFieldHint"
                app:boxStrokeColor="@color/colorPrimary"
                app:passwordToggleEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/phoneEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:textColor="@color/black"
                    android:textCursorDrawable="@null"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Address Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/addressTextInputLayout"
                style="@style/Login.InputField"
                android:layout_marginTop="16dp"
                android:hint="@string/form_field_address"
                app:startIconDrawable="@drawable/ic_location"
                app:startIconTint="@color/inputFieldHint"
                app:hintTextColor="@color/inputFieldHint"
                app:boxStrokeColor="@color/colorPrimary"
                app:passwordToggleEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/addressEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPostalAddress"
                    android:textColor="@color/black"
                    android:textCursorDrawable="@null"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Notes Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/notesTextInputLayout"
                style="@style/Login.InputField"
                android:layout_marginTop="16dp"
                android:hint="@string/form_field_notes"
                app:startIconDrawable="@drawable/ic_note"
                app:startIconTint="@color/inputFieldHint"
                app:hintTextColor="@color/inputFieldHint"
                app:boxStrokeColor="@color/colorPrimary"
                app:passwordToggleEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/notesEditText"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:inputType="textMultiLine"
                    android:gravity="top|start"
                    android:textColor="@color/black"
                    android:textCursorDrawable="@null"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Dropdown Example (using Spinner) -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Login.InputField"
                android:layout_marginTop="16dp"
                android:hint="@string/form_field_select_category"
                app:boxStrokeColor="@color/colorPrimary"
                app:hintTextColor="@color/inputFieldHint">

                <Spinner
                    android:id="@+id/categorySpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:prompt="@string/form_field_dropdown_hint"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Date Picker Button Example -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/datePickerButton"
                style="@style/Login.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/form_field_select_date"
                app:icon="@drawable/ic_calendar"
                app:iconTint="@color/white"
                app:layout_constraintTop_toBottomOf="@+id/notesTextInputLayout"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:backgroundTint="@color/formSubmitButton" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- Submit Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/submitButton"
        style="@style/Login.Button"
        android:text="@string/form_submit_button"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
