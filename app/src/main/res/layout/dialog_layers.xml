<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <!-- 標題 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="@string/layers_title"
            android:textColor="@color/text_grey"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- 選項 1：電子地圖 -->
        <LinearLayout
            android:id="@+id/rowNormalMap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="8dp"
            android:paddingHorizontal="12dp">

            <!-- 選取指示器（單選框） -->
            <ImageView
                android:id="@+id/icRadioNormal"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_radio_unchecked"
                android:contentDescription="選取狀態" />

            <!-- 地圖類型圖示 -->
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="12dp"
                android:src="@drawable/ic_map_normal"
                android:contentDescription="電子地圖" />

            <!-- 文字描述 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/map_normal"
                android:textColor="@color/text_grey"
                android:textSize="16sp" />

        </LinearLayout>

        <!-- 選項 2：衛星地圖 -->
        <LinearLayout
            android:id="@+id/rowSatelliteMap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="8dp"
            android:paddingHorizontal="12dp">

            <!-- 選取指示器（單選框） -->
            <ImageView
                android:id="@+id/icRadioSatellite"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_radio_unchecked"
                android:contentDescription="選取狀態" />

            <!-- 地圖類型圖示 -->
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="12dp"
                android:src="@drawable/ic_map_satellite"
                android:contentDescription="衛星地圖" />

            <!-- 文字描述 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/map_satellite"
                android:textColor="@color/text_grey"
                android:textSize="16sp" />

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
