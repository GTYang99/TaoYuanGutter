<?xml version="1.0" encoding="utf-8"?>
<!--
    側溝檢視 — 基本資料分頁（唯讀）
    欄位對應文件 桃園側溝分析文件_檢視欄位：
      SPI_NUM  / SPI_TYP  / STR_X / STR_Y / STR_LE
      END_X    / END_Y    / END_LE / NODE_XY
      STR_DEP  / END_DEP  / STR_WID / END_WID
      LENG     / SLOP     / NOTE
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp">

        <!-- ① SPI_NUM 側溝編號 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="側溝編號"
            android:textSize="13sp"
            android:textColor="@color/textColorSecondary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvSpiNum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:gravity="center_vertical"
            android:textSize="15sp"
            android:textColor="@color/textColorPrimary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="@drawable/bg_inspect_field"
            android:layout_marginBottom="16dp" />

        <!-- ② SPI_TYP 側溝形式 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="側溝形式"
            android:textSize="13sp"
            android:textColor="@color/textColorSecondary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvSpiTyp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:gravity="center_vertical"
            android:textSize="15sp"
            android:textColor="@color/textColorPrimary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="@drawable/bg_inspect_field"
            android:layout_marginBottom="16dp" />

        <!-- ③ STR_X 起點X（E）座標 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="起點X（E）座標"
            android:textSize="13sp"
            android:textColor="@color/textColorSecondary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvStrX"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:gravity="center_vertical"
            android:textSize="15sp"
            android:textColor="@color/textColorPrimary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="@drawable/bg_inspect_field"
            android:layout_marginBottom="16dp" />

        <!-- ④ STR_Y 起點Y（N）座標 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="起點Y（N）座標"
            android:textSize="13sp"
            android:textColor="@color/textColorSecondary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvStrY"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:gravity="center_vertical"
            android:textSize="15sp"
            android:textColor="@color/textColorPrimary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="@drawable/bg_inspect_field"
            android:layout_marginBottom="16dp" />

        <!-- ⑤ STR_LE 起點Z座標 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="起點Z座標"
            android:textSize="13sp"
            android:textColor="@color/textColorSecondary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvStrLe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:gravity="center_vertical"
            android:textSize="15sp"
            android:textColor="@color/textColorPrimary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="@drawable/bg_inspect_field"
            android:layout_marginBottom="16dp" />

        <!-- ⑥ END_X 終點X（E）座標 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="終點X（E）座標"
            android:textSize="13sp"
            android:textColor="@color/textColorSecondary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvEndX"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:gravity="center_vertical"
            android:textSize="15sp"
            android:textColor="@color/textColorPrimary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="@drawable/bg_inspect_field"
            android:layout_marginBottom="16dp" />

        <!-- ⑦ END_Y 終點Y（N）座標 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="終點Y（N）座標"
            android:textSize="13sp"
            android:textColor="@color/textColorSecondary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvEndY"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:gravity="center_vertical"
            android:textSize="15sp"
            android:textColor="@color/textColorPrimary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="@drawable/bg_inspect_field"
            android:layout_marginBottom="16dp" />

        <!-- ⑧ END_LE 終點Z座標 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="終點Z座標"
            android:textSize="13sp"
            android:textColor="@color/textColorSecondary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvEndLe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:gravity="center_vertical"
            android:textSize="15sp"
            android:textColor="@color/textColorPrimary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="@drawable/bg_inspect_field"
            android:layout_marginBottom="16dp" />

        <!-- ⑨ NODE_XY 節點座標（X,Y 逗號分隔，多節點以底線分隔） -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="節點座標"
            android:textSize="13sp"
            android:textColor="@color/textColorSecondary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvNodeXy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:gravity="center_vertical|start"
            android:textSize="14sp"
            android:textColor="@color/textColorPrimary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="@drawable/bg_inspect_field"
            android:layout_marginBottom="16dp" />

        <!-- ⑩ STR_DEP 起點深度（m） -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="起點深度（m）"
            android:textSize="13sp"
            android:textColor="@color/textColorSecondary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvStrDep"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:gravity="center_vertical"
            android:textSize="15sp"
            android:textColor="@color/textColorPrimary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="@drawable/bg_inspect_field"
            android:layout_marginBottom="16dp" />

        <!-- ⑪ END_DEP 終點深度（m） -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="終點深度（m）"
            android:textSize="13sp"
            android:textColor="@color/textColorSecondary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvEndDep"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:gravity="center_vertical"
            android:textSize="15sp"
            android:textColor="@color/textColorPrimary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="@drawable/bg_inspect_field"
            android:layout_marginBottom="16dp" />

        <!-- ⑫ STR_WID 起點頂寬（m） -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="起點頂寬（m）"
            android:textSize="13sp"
            android:textColor="@color/textColorSecondary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvStrWid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:gravity="center_vertical"
            android:textSize="15sp"
            android:textColor="@color/textColorPrimary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="@drawable/bg_inspect_field"
            android:layout_marginBottom="16dp" />

        <!-- ⑬ END_WID 終點頂寬（m） -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="終點頂寬（m）"
            android:textSize="13sp"
            android:textColor="@color/textColorSecondary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvEndWid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:gravity="center_vertical"
            android:textSize="15sp"
            android:textColor="@color/textColorPrimary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="@drawable/bg_inspect_field"
            android:layout_marginBottom="16dp" />

        <!-- ⑭ LENG 側溝長度（m） -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="側溝長度（m）"
            android:textSize="13sp"
            android:textColor="@color/textColorSecondary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvLeng"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:gravity="center_vertical"
            android:textSize="15sp"
            android:textColor="@color/textColorPrimary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="@drawable/bg_inspect_field"
            android:layout_marginBottom="16dp" />

        <!-- ⑮ SLOP 坡度（%） -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="坡度（%）"
            android:textSize="13sp"
            android:textColor="@color/textColorSecondary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvSlop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:gravity="center_vertical"
            android:textSize="15sp"
            android:textColor="@color/textColorPrimary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="@drawable/bg_inspect_field"
            android:layout_marginBottom="16dp" />

        <!-- ⑯ NOTE 補充說明 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="補充說明"
            android:textSize="13sp"
            android:textColor="@color/textColorSecondary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="80dp"
            android:gravity="top|start"
            android:textSize="15sp"
            android:textColor="@color/textColorPrimary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="@drawable/bg_inspect_field"
            android:layout_marginBottom="16dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
